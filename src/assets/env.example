# ===================================================================================
# Node42 Configuration
# ===================================================================================
# This file contains environment variables for CLI, sender, and receiver.
#
# DEPLOYMENT CONTEXTS:
#   1. Local CLI       — edit and copy to ~/.node42/.env.<environment>
#   2. AWS Lambda      — set in serverless.yml provider.environment
#   3. Azure Functions — set via az functionapp config appsettings set
#   4. Cloudflare      — set via wrangler secret put
#   5. Shell scripts   — export before running (export VAR=value)
#
# NEVER commit .env to git — add to .gitignore!
# ===================================================================================


# -----------------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------------
N42_ENV=test                           # Environment: test | production
N42_LOG_LEVEL=info                     # Logging: debug | info | warn | error


# -----------------------------------------------------------------------------------
# Database Adapter
# -----------------------------------------------------------------------------------
# Local CLI (default)
N42_DB_ADAPTER=cli-json-db
N42_DB_TABLE_CLI=CliEvents             # DynamoDB CLI table name (cli-aws-dynamo-db only)

# Sender adapters (cloud)
# N42_DB_ADAPTER=sender-aws-dynamo-db
# N42_DB_ADAPTER=sender-azure-cosmos-db

# Receiver adapters (cloud)
# N42_DB_ADAPTER=receiver-aws-dynamo-db
# N42_DB_ADAPTER=receiver-azure-cosmos-db


# -----------------------------------------------------------------------------------
# Storage Adapter
# -----------------------------------------------------------------------------------
# N42_STORAGE_ADAPTER=receiver-aws-s3
# N42_STORAGE_ADAPTER=receiver-azure-blob


# -----------------------------------------------------------------------------------
# Receiver
# -----------------------------------------------------------------------------------
# N42_RECEIVER_CERT_ID=051729ab-...         # System certificate UUID in Identity store
# N42_RECEIVER_INBOUND_PATH=as4             # Inbound AS4 endpoint path
                                            # (cloud deployment only, no leading /)
# N42_MLS_ENABLED=true                      # Enable async MLS (Message Level Status) responses to C2
                                            # (cloud deployment only)


# -----------------------------------------------------------------------------------
# Sender
# -----------------------------------------------------------------------------------
# N42_SENDER_CERT_ID=051729ab-...           # System certificate UUID in Identity store
# N42_SENDER_INBOUND_PATH=as4               # Inbound AS4 endpoint path
# N42_SENDER_CERT_PATH=/path/to/cert.pem
# N42_SENDER_KEY_PATH=/path/to/key.pem


# -----------------------------------------------------------------------------------
# AWS (Lambda / DynamoDB / S3)
# -----------------------------------------------------------------------------------
# AWS_REGION=...
# AWS_PROFILE=...                      # AWS SSO profile (local only)
# AWS_BUCKET=...                       # S3 bucket name

# Cloud credentials (Cloudflare Workers / Azure — not needed on Lambda)
# CLOUD_AWS_ACCESS_KEY=...
# CLOUD_AWS_SECRET_KEY=...

# -----------------------------------------------------------------------------------
# AWS Secrets Manager
# -----------------------------------------------------------------------------------
# N42_SECRETS_ADAPTER=receiver-aws-sec-mgr


# -----------------------------------------------------------------------------------
# Azure (Azure Functions / CosmosDB / Blob Storage)
# -----------------------------------------------------------------------------------
# N42_RECEIVER_INBOUND_PATH=as4
# N42_ENV=test
# N42_RECEIVER_CERT_ID=...
# N42_DB_ADAPTER=receiver-azure-cosmos-db
# N42_STORAGE_ADAPTER=receiver-azure-blob

# COSMOS_ENDPOINT=https://n42-cosmos.documents.azure.com:443/
# COSMOS_KEY=...
# COSMOS_DATABASE=n42

# AZURE_STORAGE_CONNECTION_STRING=...
# AZURE_BLOB_CONTAINER=...

# Azure Functions internal (set automatically on Azure, required locally)
# AzureWebJobsStorage=$AZURE_STORAGE_CONNECTION_STRING


# -----------------------------------------------------------------------------------
# Cloudflare Workers (set via wrangler secret put, not in .env)
# -----------------------------------------------------------------------------------
# N42_RECEIVER_INBOUND_PATH=as4
# N42_ENV=test
# N42_RECEIVER_CERT_ID=...
# N42_DB_ADAPTER=receiver-cf-d1-db
# N42_STORAGE_ADAPTER=receiver-cf-r2

# CLOUD_AWS_ACCESS_KEY=...
# CLOUD_AWS_SECRET_KEY=...

# AWS_REGION=...
# AWS_BUCKET=...