# ===================================================================================
# Node42 eDelivery Configuration
# ===================================================================================
# This file contains environment variables for CLI, sender, and receiver.
#
# DEPLOYMENT CONTEXTS:
# 1. Local CLI/development:
#              Manual setup — edit and copy this file to ~/.node42
#              .env.test is created during npm install and loaded automatically
#
# 2. Lambda (serverless): Set in serverless.yml provider.environment
#
# 3. Shell scripts: Export before running (export VAR=value)
#
# NEVER commit .env to git - add it to .gitignore!
# ==================================================================================

# ----------------------------------------------------------------------------------
# Environment
# ----------------------------------------------------------------------------------
N42_ENV=test                           # Environment: test, prod
N42_LOG_LEVEL=info                     # Logging: debug, info, warn, error

# ----------------------------------------------------------------------------------
# Database Adapter (sender & receiver)
# ----------------------------------------------------------------------------------
N42_DB_TABLE=Transactions              # DynamoDB table name
N42_DB_ADAPTER=sender-json-db

# Adapter options
# N42_DB_ADAPTER=sender-aws-dynamo-db         
# N42_DB_ADAPTER=receiver-aws-dynamo-db
# N42_DB_ADAPTER=receiver-azure-cosmos-db

# ----------------------------------------------------------------------------------
# Receiver Configuration
# ----------------------------------------------------------------------------------
# N42_RECEIVER_CERT_ID=051729ab-...    # System certificate ID for receiver AP

# ----------------------------------------------------------------------------------
# Sender Configuration
# ----------------------------------------------------------------------------------
# N42_SENDER_CERT_ID=051729ab-...
# N42_SENDER_CERT_PATH=/path/to/cert.pem
# N42_SENDER_KEY_PATH=/path/to/key.pem

# ----------------------------------------------------------------------------------
# AWS Configuration (for Lambda/DynamoDB/S3)
# ----------------------------------------------------------------------------------
AWS_REGION=eu-north-1
AWS_PROFILE=default                    # AWS SSO profile name

# ----------------------------------------------------------------------------------
# AWS S3
# ----------------------------------------------------------------------------------
# AWS_BUCKET=n42-...                   # AWS S3 bucket name